<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<title>{{ report.title }}</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body {
    margin:0;
    background:#060b18;
    color:#e5e7eb;
    font-family:"Segoe UI",Arial,sans-serif;
    padding:25px;
}


.header {

    background:#111827;
    border:1px solid #334155;
    border-radius:18px;
    padding:25px;
}


.header h1 {

    margin:0;
    font-size:32px;

}


.subtitle {

    color:#94a3b8;
    margin-top:8px;

}


.cards {

display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:15px;
margin:25px 0;

}


.card {

background:#111827;
border:1px solid #334155;
border-radius:15px;
padding:20px;

}


.number {

font-size:38px;
font-weight:bold;

}


.label {

color:#94a3b8;

}


.section {

font-size:24px;
font-weight:bold;
margin-top:35px;

}


.grid {

display:grid;
grid-template-columns:repeat(auto-fit,minmax(350px,1fr));
gap:20px;

}


.case {

background:#0f172a;
border:1px solid #334155;
border-radius:18px;
padding:22px;

}


.badge {

border-radius:20px;
padding:5px 12px;
border:1px solid #ef4444;
color:#f87171;
font-size:13px;

}


.story {

background:#020617;
padding:15px;
border-radius:12px;
margin-top:15px;

}


.tag {

display:inline-block;
background:#172554;
border:1px solid #2563eb;
border-radius:20px;
padding:5px 10px;
margin:4px;

}


.timeline {

border-left:2px solid #2563eb;
padding-left:20px;

}


.event {

margin-bottom:18px;

}


.time {

color:#64748b;
font-size:12px;

}


.entity {

color:#60a5fa;

}


.finding {

background:#111827;
border-radius:12px;
padding:15px;
margin-bottom:10px;

}


.evidence {
    margin-top:15px;
}

.evidence-box {
    margin-top:15px;
    border:1px solid #334155;
    border-radius:12px;
    background:#020617;
    padding:10px;
}

.evidence-box summary {
    cursor:pointer;
    color:#60a5fa;
    font-weight:bold;
}

.evidence-content {
    max-height:300px;
    overflow-y:auto;
    margin-top:15px;
    padding:10px;
}

.evidence-content pre {
    white-space:pre-wrap;
    word-break:break-word;
    font-size:12px;
    color:#cbd5e1;
}


button {

background:#2563eb;
color:white;
border:0;
padding:10px 15px;
border-radius:8px;

}


.raw-data {
    max-height:300px;
    overflow:auto;
    white-space:pre-wrap;
    word-break:break-word;
    background:#020617;
    border:1px solid #334155;
    padding:12px;
    border-radius:10px;
    font-size:12px;
}


.raw-data summary {
    cursor:pointer;
    color:#60a5fa;
    font-weight:bold;
}



.long-text {

max-height:300px;
overflow:auto;
background:#020617;
border:1px solid #334155;
border-radius:10px;
padding:12px;
white-space:pre-wrap;
word-break:break-word;
font-size:12px;

}


details summary {

cursor:pointer;
color:#60a5fa;
font-weight:bold;

}


.long-text {

max-height:300px;
overflow:auto;
background:#020617;
border:1px solid #334155;
border-radius:10px;
padding:12px;
white-space:pre-wrap;
word-break:break-word;
font-size:12px;

}


details summary {

cursor:pointer;
color:#60a5fa;
font-weight:bold;

}

</style>

</head>


<body>


<div class="header">

<h1>
🛡 SOC Investigation Dashboard
</h1>

<div class="subtitle">

{{ report.generated_at_display }}

</div>

</div>



<div class="cards">


<div class="card">
<div class="number">
{{ report.total_findings }}
</div>
<div class="label">
Open Findings
</div>
</div>


<div class="card">
<div class="number">
{{ report.cases|length if report.cases else 0 }}
</div>
<div class="label">
Active Cases
</div>
</div>


<div class="card">
<div class="number">
{{ report.high_findings }}
</div>
<div class="label">
High Severity
</div>
</div>


<div class="card">
<div class="number">
{{ report.affected_agents|length }}
</div>
<div class="label">
Affected Hosts
</div>
</div>


</div>




<div class="section">

📊 Executive Summary

</div>


<div class="card">

<p>
Total Findings:
<b>{{ report.total_findings }}</b>
</p>

<p>
High Severity:
<b>{{ report.high_findings }}</b>
</p>

<p>
Hosts:
<b>{{ report.affected_agents|join(", ") }}</b>
</p>

</div>





<div class="section">

🚨 Incident Cases

</div>


<div class="grid">


{% for case in report.cases %}


<div class="case">


<span class="badge">
{{ case.severity }}
</span>


<h2>

{{ case.case_id }}

</h2>


<h3>

{{ case.title }}

</h3>



<h4>
Attack Story
</h4>


<div class="story">

{{ case.attack_story }}

</div>



<h4>

MITRE ATT&CK

</h4>


{% for technique in case.mitre_techniques %}

<span class="tag">

{{ technique }}

</span>

{% endfor %}



<h4>
Entities
</h4>


{% for key,value in case.entities.items() %}

<p>

<span class="entity">
{{ key }}
</span>
:
{% if value|string|length > 500 %}

<details>

<summary>
Show large evidence ({{ value|string|length }} chars)
</summary>

<pre class="long-text">{% if value|string|length > 500 %}

<details>

<summary>
Show large evidence ({{ value|string|length }} chars)
</summary>

<pre class="long-text">{{ value }}</pre>

</details>

{% else %}

{{ value }}

{% endif %}</pre>

</details>

{% else %}

{% if value|string|length > 500 %}

<details>

<summary>
Show large evidence ({{ value|string|length }} chars)
</summary>

<pre class="long-text">{{ value }}</pre>

</details>

{% else %}

{{ value }}

{% endif %}

{% endif %}

</p>

{% endfor %}




<h4>
Timeline
</h4>


<div class="timeline">


{% for event in case.timeline %}


<div class="event">

<div class="time">

{{ event.timestamp }}

</div>


<b>

{{ event.event }}

</b>


</div>


{% endfor %}


</div>



</div>


{% endfor %}


</div>






<div class="section">

🔎 Security Findings

</div>


{% for finding in report.findings %}


<div class="finding">


<h3>

{{ finding.title }}

</h3>


Severity:

<b>

{{ finding.severity }}

</b>



<p>

{{ finding.description }}

</p>



<details class="evidence-box">

<summary>
🔎 View Evidence
</summary>

<div class="evidence-content">

{% for key,value in finding.evidence.items() %}

<p>
<b>{{ key }}</b>
</p>

<pre>{% if value|string|length > 500 %}

<details>

<summary>
Show large evidence ({{ value|string|length }} chars)
</summary>

<pre class="long-text">{% if value|string|length > 500 %}

<details>

<summary>
Show large evidence ({{ value|string|length }} chars)
</summary>

<pre class="long-text">{{ value }}</pre>

</details>

{% else %}

{{ value }}

{% endif %}</pre>

</details>

{% else %}

{% if value|string|length > 500 %}

<details>

<summary>
Show large evidence ({{ value|string|length }} chars)
</summary>

<pre class="long-text">{{ value }}</pre>

</details>

{% else %}

{{ value }}

{% endif %}

{% endif %}</pre>

{% endfor %}

</div>

</details>


</div>


{% endfor %}



</body>

</html>




